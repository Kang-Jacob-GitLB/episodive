# Auto detect text files and ensure LF line endings
* text=auto eol=lf

# Kotlin
*.kt text eol=lf
*.kts text eol=lf

# Gradle
*.gradle text eol=lf
*.properties text eol=lf

# XML
*.xml text eol=lf

# Docs
*.md text eol=lf

# Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.keystore binary
