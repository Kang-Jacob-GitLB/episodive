{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- :*)",
      "Bash(git branch -D:*)"
    ],
    "ask": []
  }
}
