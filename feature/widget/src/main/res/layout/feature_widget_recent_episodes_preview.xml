<?xml version="1.0" encoding="utf-8"?>
<!--
  위젯 피커에서 보이는 Recent Episodes 프리뷰.
  Episodive 디자인:
  - surfaceContainerLight (#F9EAEA) 카드 배경 + 16dp round
  - primary (#F5332C) 14sp Bold 헤더
  - 44dp artwork (8dp round), 13sp/11sp 타이포
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feature_widget_preview_card_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/feature_widget_recent_episodes_header"
            android:textColor="#FFF5332C"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/feature_widget_preview_artwork_bg_small"
                android:contentDescription="@string/feature_widget_recent_episodes_artwork_desc"
                android:scaleType="centerInside"
                android:src="@drawable/feature_widget_ic_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/feature_widget_now_playing_preview_title"
                    android:textColor="#FF201A1A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/feature_widget_now_playing_preview_subtitle"
                    android:textColor="#FF534341"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/feature_widget_preview_artwork_bg_small"
                android:contentDescription="@string/feature_widget_recent_episodes_artwork_desc"
                android:scaleType="centerInside"
                android:src="@drawable/feature_widget_ic_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/feature_widget_now_playing_preview_title"
                    android:textColor="#FF201A1A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/feature_widget_now_playing_preview_subtitle"
                    android:textColor="#FF534341"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
